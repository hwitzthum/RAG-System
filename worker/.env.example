WORKER_NAME=rag-ingestion-worker
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_MAX_RETRIES=3
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RAG_STORAGE_BUCKET=documents
OPENAI_API_KEY=your-openai-key

WORKER_CHUNK_TARGET_TOKENS=700
WORKER_CHUNK_OVERLAP_TOKENS=120
WORKER_CHUNK_MIN_CHARS=120

WORKER_CONTEXT_ENABLED=true
WORKER_CONTEXT_MODEL=gpt-4o-mini
WORKER_CONTEXT_MAX_CHARS=280

WORKER_EMBEDDING_MODEL=text-embedding-3-large
WORKER_EMBEDDING_DIM=1024
WORKER_EMBEDDING_DIMENSIONS=1024
WORKER_EMBEDDING_BATCH_SIZE=32
WORKER_OPENAI_TIMEOUT_SECONDS=40

WORKER_OCR_FALLBACK_ENABLED=true
WORKER_LOCK_TIMEOUT_SECONDS=900
WORKER_CHUNK_INSERT_BATCH_SIZE=100
ANTHROPIC_API_KEY=your-anthropic-api-key
