{
  "name": "rag-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"next,worker\" --prefix-colors \"blue,green\" \"next dev -p 3001\" \"npm run dev:worker\"",
    "dev:next": "next dev -p 3001",
    "dev:worker": "node -r dotenv/config --import tsx scripts/ingestion/run-worker.ts dotenv_config_path=.env.local",
    "ingestion:worker": "node -r dotenv/config --import tsx scripts/ingestion/run-worker.ts dotenv_config_path=.env.local",
    "ingestion:worker:once": "node -r dotenv/config --import tsx scripts/ingestion/run-worker.ts --once dotenv_config_path=.env.local",
    "ingestion:reconcile": "node -r dotenv/config --import tsx scripts/ingestion/reconcile-state.ts dotenv_config_path=.env.local",
    "ingestion:reconcile:apply": "node -r dotenv/config --import tsx scripts/ingestion/reconcile-state.ts --apply dotenv_config_path=.env.local",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "infra:check-env": "node scripts/infrastructure/validate-env.mjs",
    "infra:check-env:web": "node scripts/infrastructure/validate-env.mjs --target web --file .env.local",
    "infra:check-env:staging": "node scripts/infrastructure/validate-env.mjs --target staging --file .env.staging",
    "infra:preflight": "bash scripts/infrastructure/preflight.sh",
    "infra:vercel:prepare-staging": "node scripts/infrastructure/prepare-vercel-staging-env.mjs --env-file .env.staging --env-template .env.staging.example",
    "infra:vercel:readiness": "node scripts/infrastructure/check-vercel-onboarding-readiness.mjs --target presignup --no-fail-on-gate",
    "infra:vercel:readiness:postlink": "node scripts/infrastructure/check-vercel-onboarding-readiness.mjs --target postlink",
    "infra:vercel:sync-ids": "node scripts/infrastructure/sync-vercel-project-ids.mjs --env-file .env.staging --project-file .vercel/project.json",
    "db:validate:migrations": "node scripts/database/validate-migrations.mjs",
    "test:security": "tsx --test tests/*.test.ts",
    "eval:dataset:generate": "tsx scripts/evaluation/generate-dataset.ts",
    "eval:dataset:validate": "tsx scripts/evaluation/validate-dataset.ts",
    "eval:benchmark": "tsx scripts/evaluation/run-benchmark.ts --mode live",
    "eval:benchmark:dry": "tsx scripts/evaluation/run-benchmark.ts --mode dry-run --no-fail-on-gate",
    "eval:smoke": "tsx scripts/evaluation/run-benchmark.ts --mode live --sample 25 --no-fail-on-gate",
    "obs:validate": "node scripts/production/validate-observability.mjs",
    "obs:ingestion:check": "tsx scripts/production/check-ingestion-health.ts --mode live",
    "obs:ingestion:check:dry": "tsx scripts/production/check-ingestion-health.ts --mode dry-run --no-fail-on-gate",
    "perf:load": "tsx scripts/production/run-load-test.ts --mode live",
    "perf:load:dry": "tsx scripts/production/run-load-test.ts --mode dry-run --duration-seconds 60 --concurrency 20",
    "perf:resilience": "tsx scripts/production/run-resilience-checks.ts --mode live",
    "perf:resilience:dry": "tsx scripts/production/run-resilience-checks.ts --mode dry-run",
    "perf:soak:verify": "tsx scripts/production/verify-staging-soak.ts --mode live",
    "perf:soak:verify:dry": "tsx scripts/production/verify-staging-soak.ts --mode dry-run --no-fail-on-gate --no-write-latest",
    "release:readiness": "tsx scripts/production/generate-release-readiness.ts --benchmark-gate-mode live",
    "release:readiness:precutover": "tsx scripts/production/generate-release-readiness.ts --benchmark-gate-mode allow-dry",
    "release:matrix:precutover": "tsx scripts/production/run-validation-matrix.ts --mode precutover",
    "release:matrix:strict": "tsx scripts/production/run-validation-matrix.ts --mode strict"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@napi-rs/canvas": "^0.1.96",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.57.2",
    "@tailwindcss/typography": "^0.5.19",
    "cohere-ai": "^7.20.0",
    "docx": "^9.6.0",
    "jose": "^6.0.13",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "pdfjs-dist": "^5.5.207",
    "pdfkit": "^0.17.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5"
  },
  "overrides": {
    "pdfkit": {
      "jpeg-exif": "1.1.4"
    }
  }
}
