NODE_ENV=development
NEXT_PUBLIC_APP_NAME=RAG System
# App URL used for email confirmation redirect links
NEXT_PUBLIC_APP_URL=http://localhost:3001
INGESTION_BATCH_SIZE=50
INGESTION_LOCK_TIMEOUT_SECONDS=900
# CRON_SECRET must be at least 32 characters of random data (use: openssl rand -hex 32)
CRON_SECRET=your-long-random-cron-secret-minimum-32-chars
# Supabase project URL and anon key (these are public/safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
AUTH_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/keys
AUTH_DEV_INSECURE_BYPASS=false
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=30
OPENAI_API_KEY=your-openai-key
OPENAI_BYOK_VAULT_KEY=your-32-byte-base64-vault-key
OPENAI_BYOK_VAULT_KEY_VERSION=1
RAG_QUERY_EMBEDDING_MODEL=text-embedding-3-large
RAG_QUERY_EMBEDDING_DIMENSIONS=1024
RAG_RETRIEVAL_VERSION=1
RAG_RRF_K=60
RAG_RERANK_POOL_SIZE=40
RAG_LLM_MODEL=gpt-4o-mini
RAG_LLM_MAX_OUTPUT_TOKENS=700
RAG_MIN_EVIDENCE_CHUNKS=2
RAG_MIN_RERANK_SCORE=0.25
RAG_DEFAULT_TOP_K=8
RAG_CACHE_TTL_SECONDS=86400
RAG_MAX_UPLOAD_BYTES=52428800
RAG_STORAGE_BUCKET=documents
RAG_CROSS_ENCODER_ENABLED=false
RAG_CROSS_ENCODER_MODEL=rerank-v3.5
COHERE_API_KEY=your-cohere-api-key
RAG_CONTEXTUAL_GROUPING_ENABLED=true
RAG_WEB_SEARCH_ENABLED=false
RAG_WEB_SEARCH_PROVIDER=tavily
RAG_WEB_SEARCH_API_KEY=your-tavily-api-key
RAG_WEB_SEARCH_MAX_RESULTS=5
RAG_MULTI_QUERY_ENABLED=false
RAG_MULTI_QUERY_VARIATIONS=3
ANTHROPIC_API_KEY=your-anthropic-api-key
ADMIN_EMAIL=admin@yourdomain.com
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id
